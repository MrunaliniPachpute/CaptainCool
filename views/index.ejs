<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CaptainCool AI Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=Outfit:wght@500;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <div class="header-content">
            <h1>CaptainCool <span>AI</span></h1>
            <p>Live IPL Tactical War Room</p>
            <div id="live-status-indicator" class="hidden">
                <span class="live-dot"></span>
                <span class="live-text">Data synced from CricAPI</span>
                <span class="live-time" id="last-updated-time"></span>
            </div>
        </div>
    </header>

    <main class="dashboard-container">
        
        <!-- Left Panel: Controls & Inputs -->
        <section class="panel left-panel glass-panel">
            <div class="panel-header">
                <h2>Match Parameters</h2>
            </div>
            
            <!-- Mode Switcher -->
            <div class="mode-switcher">
                <button class="mode-btn active" id="btn-manual-mode">Manual Tactical Mode</button>
                <button class="mode-btn" id="btn-live-mode"><span class="live-dot small"></span> Live Match Beta</button>
            </div>

            <!-- Live Match UI (Hidden by default) -->
            <div id="live-match-section" class="hidden glass-panel-inner">
                <button type="button" id="btn-fetch-live" class="secondary-btn">Fetch Live Matches</button>
                <div id="live-loading" class="hidden loader-container" style="margin-top: 10px;">
                    <div class="cricket-ball"></div> Fetching from CricAPI...
                </div>
                <div class="form-group" id="live-dropdown-group" style="display: none; margin-top: 15px;">
                    <label for="liveMatchSelect">Select Active Match</label>
                    <select id="liveMatchSelect">
                        <option value="">-- Choose a match --</option>
                    </select>
                </div>
            </div>

            <div class="demo-buttons" id="demo-buttons-section">
                <button type="button" class="demo-btn" data-scenario="kohli">Kohli Chase</button>
                <button type="button" class="demo-btn" data-scenario="dhoni">Dhoni Finish</button>
                <button type="button" class="demo-btn" data-scenario="russell">Russell Carnage</button>
                <button type="button" class="demo-btn" data-scenario="bumrah">Bumrah Death</button>
            </div>

            <form id="match-form">
                <div class="form-group row">
                    <div class="col">
                        <label for="battingTeam">Batting Team</label>
                        <input type="text" id="battingTeam" required placeholder="e.g., RCB">
                    </div>
                    <div class="col">
                        <label for="bowlingTeam">Bowling Team</label>
                        <input type="text" id="bowlingTeam" required placeholder="e.g., CSK">
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col">
                        <label for="score">Score</label>
                        <input type="text" id="score" required placeholder="e.g., 185">
                    </div>
                    <div class="col">
                        <label for="wickets">Wickets</label>
                        <input type="number" id="wickets" required min="0" max="10" placeholder="e.g., 4">
                    </div>
                    <div class="col">
                        <label for="overs">Overs</label>
                        <input type="text" id="overs" required placeholder="e.g., 18.2">
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col">
                        <label for="striker">Striker</label>
                        <input type="text" id="striker" required placeholder="e.g., Virat Kohli">
                    </div>
                    <div class="col">
                        <label for="nonStriker">Non-Striker</label>
                        <input type="text" id="nonStriker" required placeholder="e.g., Faf du Plessis">
                    </div>
                </div>

                <!-- Advanced Settings Accordion -->
                <div class="accordion">
                    <div class="accordion-header" id="advanced-toggle">
                        <span>Advanced Match Settings (Optional)</span>
                        <span class="icon">▼</span>
                    </div>
                    <div class="accordion-content" id="advanced-content">
                        <div class="form-group">
                            <label for="venue">Venue</label>
                            <input type="text" id="venue" placeholder="e.g., Chinnaswamy">
                        </div>
                        <div class="form-group">
                            <label for="bowlerOvers">Bowlers & Overs Left</label>
                            <input type="text" id="bowlerOvers" placeholder="e.g., Bumrah (1), Siraj (1)">
                        </div>
                        <div class="form-group row">
                            <div class="col">
                                <label for="pitchType">Pitch Type</label>
                                <select id="pitchType">
                                    <option value="">Unknown</option>
                                    <option value="Batting Paradise">Batting Paradise</option>
                                    <option value="Spin Friendly">Spin Friendly</option>
                                    <option value="Pacer Friendly">Pacer Friendly</option>
                                    <option value="Two-Paced">Two-Paced</option>
                                </select>
                            </div>
                            <div class="col">
                                <label for="dew">Dew Factor</label>
                                <select id="dew">
                                    <option value="">Unknown</option>
                                    <option value="Heavy">Heavy Dew</option>
                                    <option value="Light">Light Dew</option>
                                    <option value="None">No Dew</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="requiredRR">Required Run Rate</label>
                            <input type="text" id="requiredRR" placeholder="e.g., 12.5">
                        </div>
                        <div class="form-group row align-center">
                            <label for="impactPlayer">Impact Player Available?</label>
                            <label class="switch">
                                <input type="checkbox" id="impactPlayer">
                                <span class="slider round"></span>
                            </label>
                        </div>
                        <div class="form-group">
                            <label for="captainStyle">Captain Style</label>
                            <select id="captainStyle">
                                <option value="Balanced">Balanced</option>
                                <option value="Dhoni Mode">Dhoni Mode (Calm, Deep Game)</option>
                                <option value="Rohit Mode">Rohit Mode (Instinctive, Bowler Rotation)</option>
                                <option value="Aggressive Mode">Aggressive Mode</option>
                                <option value="Defensive Mode">Defensive Mode</option>
                            </select>
                        </div>
                    </div>
                </div>

                <button type="submit" id="submit-btn" class="primary-btn">Initialize War Room</button>
            </form>
        </section>

        <!-- Center Panel: Live Debate -->
        <section class="panel center-panel" id="debate-panel">
            <div class="panel-header">
                <h2>Live Agent Debate</h2>
            </div>
            <div class="debate-feed">
                <!-- Strategist -->
                <div class="agent-card glass-panel fade-in hidden" id="card-strategist-1">
                    <div class="agent-header">
                        <span class="agent-avatar strat-avatar">🧠</span>
                        <div>
                            <h3>Strategist</h3>
                            <span class="status">Initial Proposal</span>
                        </div>
                    </div>
                    <div class="content loading-pulse">
                        <div class="loader-container"><div class="cricket-ball"></div> Thinking...</div>
                    </div>
                </div>

                <!-- Stats Analyst -->
                <div class="agent-card glass-panel fade-in hidden" id="card-stats">
                    <div class="agent-header">
                        <span class="agent-avatar stats-avatar">📊</span>
                        <div>
                            <h3>Stats Analyst</h3>
                            <span class="status">Data Validation</span>
                        </div>
                    </div>
                    <div class="tool-calls"></div>
                    <div class="content">
                        <div class="loader-container"><div class="cricket-ball"></div> Crunching Numbers...</div>
                    </div>
                </div>

                <!-- Devil's Advocate -->
                <div class="agent-card glass-panel fade-in hidden" id="card-devil">
                    <div class="agent-header">
                        <span class="agent-avatar devil-avatar">🔥</span>
                        <div>
                            <h3>Devil's Advocate</h3>
                            <span class="status">Critique & Risk Analysis</span>
                        </div>
                    </div>
                    <div class="content">
                        <div class="loader-container"><div class="cricket-ball"></div> Finding Flaws...</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Right Panel: Final Output -->
        <section class="panel right-panel" id="final-panel">
            <div class="panel-header">
                <h2>Captain's Call</h2>
            </div>
            
            <div class="agent-card glass-panel final-decision-card fade-in hidden" id="card-strategist-final">
                <div class="agent-header">
                    <span class="agent-avatar final-avatar">👑</span>
                    <div>
                        <h3>Final Decision</h3>
                        <span class="status">Revised Plan</span>
                    </div>
                </div>
                
                <div class="confidence-section">
                    <div class="confidence-header">
                        <span>Confidence Level</span>
                        <span id="confidence-score-text">--%</span>
                    </div>
                    <div class="confidence-bar-bg">
                        <div class="confidence-bar-fill" id="confidence-bar"></div>
                    </div>
                </div>

                <div class="content final-text">
                    <div class="loader-container"><div class="cricket-ball"></div> Finalizing Strategy...</div>
                </div>
            </div>

            <div class="commentary-box glass-panel fade-in hidden" id="card-commentary">
                <div class="agent-header">
                    <span class="agent-avatar comm-avatar">🎙️</span>
                    <h3>Live Comm Box</h3>
                </div>
                <div class="content italic">
                    <div class="loader-container"><div class="cricket-ball"></div> On the mic...</div>
                </div>
            </div>
        </section>

    </main>

    <script src="/js/main.js"></script>
</body>
</html>
